<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp" android:gravity="center_vertical">

    <LinearLayout android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvLibelleCompte"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp" android:textStyle="bold"
            android:textColor="@color/primary" />
        <TextView android:id="@+id/tvNumeroCompte"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>
    <TextView android:id="@+id/tvSoldeCompte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp" android:textStyle="bold"
        android:textColor="@color/primary" />
</LinearLayout>