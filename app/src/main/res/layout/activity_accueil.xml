<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">
    <!-- En-tête bleu -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary"
        android:padding="@dimen/marge_large">
        <TextView android:id="@+id/tvBienvenue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/accueil_bienvenue"
            android:textSize="@dimen/texte_titre"
            android:textColor="@color/text_on_primary"
            android:textStyle="bold" /> </LinearLayout>
    <!-- La grille sera ajoutée ici -->

    <GridLayout android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:rowCount="3"
        android:columnCount="2"
        android:padding="@dimen/marge_standard"
        android:useDefaultMargins="true">
        <!-- 6 CardView seront ajoutées ici -->

        <androidx.cardview.widget.CardView
            android:id="@+id/cardTransactions"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/card_bg">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:padding="@dimen/card_padding">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@string/desc_transactions"
                    app:srcCompat="@drawable/ic_transactions_24"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/carte_transactions"
                    android:textSize="@dimen/texte_carte"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardRecherche"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/card_bg">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:padding="@dimen/card_padding">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍" android:textSize="32sp" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/carte_recherche"
                    android:textSize="@dimen/texte_carte"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardVirement"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/card_bg">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:padding="@dimen/card_padding">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💸" android:textSize="32sp" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/carte_virement"
                    android:textSize="@dimen/texte_carte"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/cardComptes"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/card_bg">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:padding="@dimen/card_padding">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💳" android:textSize="32sp" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/carte_comptes"
                    android:textSize="@dimen/texte_carte"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/cardStats"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/card_bg">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:padding="@dimen/card_padding">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊" android:textSize="32sp" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/carte_stats"
                    android:textSize="@dimen/texte_carte"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:id="@+id/cardParams"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_rowWeight="1"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/card_bg">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:padding="@dimen/card_padding">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙️" android:textSize="32sp" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/carte_params"
                    android:textSize="@dimen/texte_carte"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </GridLayout>

    <Button
        android:id="@+id/btnDeconnexion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/marge_standard"
        android:layout_marginEnd="@dimen/marge_standard"
        android:layout_marginBottom="@dimen/marge_standard"
        android:text="@string/btn_deconnexion" />

</LinearLayout>
